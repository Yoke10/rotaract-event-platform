rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── PUBLIC: Events are readable by anyone (no login required) ───────────
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data != null;
    }

    // ─── USERS: Users can read/write their own document only ─────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── BOOKINGS: Only authenticated users, own bookings ────────────────────
    match /bookings/{bookingId} {
      allow read, write: if request.auth != null;
    }

    // ─── ADMINS: Only readable by the admin themselves ────────────────────────
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // Managed via Firebase Console only
    }

    // ─── DEFAULT DENY ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
